{
  "name": "node-graphql-api",
  "version": "1.0.0",
  "description": "Production-ready GraphQL API with Apollo Server 4, TypeScript, DataLoader, JWT auth, WebSocket subscriptions, and multi-tenant SaaS architecture",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "graphql",
    "apollo-server",
    "typescript",
    "dataloader",
    "jwt",
    "websocket",
    "subscriptions",
    "multi-tenant",
    "saas"
  ],
  "author": "Solaris Technologies",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.13.0",
    "@graphql-tools/schema": "^10.0.31",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dataloader": "^2.2.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^6.0.8",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}